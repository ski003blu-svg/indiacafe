{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@clerk/express": "^2.1.14",
    "@clerk/shared": "^4.10.1",
    "@paypal/paypal-server-sdk": "^2.3.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "http-proxy-middleware": "^4.0.0",
    "nodemailer": "^8.0.7",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
